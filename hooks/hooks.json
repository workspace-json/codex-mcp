{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/pre-edit-check.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking workspace fragility and co-change history"
          }
        ]
      }
    ]
  }
}
