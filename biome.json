{
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "files": {
    "include": ["src", "tests", "scripts", "hooks", "*.json", "*.mjs", "*.ts"],
    "ignore": [
      ".claude",
      ".local",
      ".vscode",
      "dist",
      "node_modules",
      "fixture",
      "assets",
      "extension",
      "scripts/extract-session*.mjs"
    ]
  }
}
